# HPV Vaccine Chatbot - Environment Variables Configuration
# ============================================================
# Copy this file to .env and fill in your values for local development.
# For production deployment (Docker/Google Cloud Run), set these as environment
# variables in your deployment configuration instead of using .env files.

# ----------------------------------------
# Required API Keys
# ----------------------------------------

# OpenAI API Key - Required for embeddings and chat completions
# Get yours at: https://platform.openai.com/api-keys
OPENAI_API_KEY=your-openai-api-key-here

# Pinecone API Key - Required for vector database storage
# Get yours at: https://www.pinecone.io/
PINECONE_API_KEY=your-pinecone-api-key-here

# Pinecone Index Name - The name of your Pinecone index
# Make sure the index exists in your Pinecone dashboard
PINECONE_INDEX_NAME=hpv-guide-v2

# ----------------------------------------
# Flask Configuration (Optional)
# ----------------------------------------

# Flask Secret Key - Used for session management
# Generate a secure random key for production:
#   python -c "import secrets; print(secrets.token_hex(32))"
# If not set, a random key is generated on each restart (sessions won't persist)
SECRET_KEY=your-flask-secret-key-here

# ----------------------------------------
# Application Parameters (Optional)
# ----------------------------------------

# Context synthesis strategy (default: first available)
# Options: create-and-refine, tree-summarization, async-tree-summarization
# SYNTHESIS_STRATEGY=async-tree-summarization

# Number of chunks to return from similarity search (default: 2)
# RAG_K=2

# Maximum number of tokens to generate (default: 512)
# MAX_NEW_TOKENS=512

# Document chunk size for text splitting (default: 1000)
# CHUNK_SIZE=1000

# Document chunk overlap (default: 50)
# CHUNK_OVERLAP=50

# ----------------------------------------
# Server Configuration (Optional)
# ----------------------------------------

# Port for the server (default: 8000 for Gunicorn, 8080 for Cloud Run)
# PORT=8000
